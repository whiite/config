# Style
theme = nightfox
background-opacity = 0.7
background-blur = 20
macos-titlebar-style = tabs
macos-window-buttons = hidden

# Utility
shell-integration-features = no-cursor,ssh-env,ssh-terminfo
notify-on-command-finish = unfocused
notify-on-command-finish-action = no-bell,notify
notify-on-command-finish-after = 90s

# Font & Cursor
font-family = "Fira Code"
font-size = 13

# Quick terminal
quick-terminal-position = "top"
quick-terminal-animation-duration = 0.05

# Bindings
keybind = global:cmd+ctrl+t=toggle_quick_terminal

## Movement
# NOTE: `all:` prefix here ensures these take precedence over built-in shortcuts
keybind = super+alt+left=goto_split:left
keybind = all:super+alt+h=goto_split:left

keybind = super+alt+right=goto_split:right
keybind = all:super+alt+l=goto_split:right

keybind = super+alt+up=goto_split:up
keybind = all:super+alt+k=goto_split:up

keybind = super+alt+down=goto_split:down
keybind = all:super+alt+j=goto_split:down

